# Relationship App - Development Environment

APP_VARIANT=relationship

# API Configuration
API_URL=https://api.dev.stellium.ai

# Google Services
# Get this from Google Cloud Console
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE

# RevenueCat Test Store (development builds only; never use this key in production)
IRIS_REVENUECAT_API_KEY=YOUR_IRIS_REVENUECAT_TEST_STORE_PUBLIC_API_KEY

# Firebase Project
FIREBASE_PROJECT_ID=stellium-relationship-dev

# Relationship App Backend Auth (Service Account)
# The service account key JSON file is at: secrets/relationship-app-backend-dev.json
# For backend deployment, set GOOGLE_APPLICATION_CREDENTIALS to point to this file,
# or use these individual env vars:
RELATIONSHIP_FIREBASE_SERVICE_ACCOUNT_EMAIL=relationship-app-backend@stellium-relationship-dev.iam.gserviceaccount.com
RELATIONSHIP_FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./secrets/relationship-app-backend-dev.json
RELATIONSHIP_FIREBASE_PROJECT_ID=stellium-relationship-dev

# Environment identifier
ENV=development
