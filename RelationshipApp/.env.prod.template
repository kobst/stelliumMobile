# Relationship App - Production Environment

APP_VARIANT=relationship

# API Configuration
API_URL=https://api.stellium.ai

# Google Services
# Get this from Google Cloud Console
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE

# RevenueCat platform public key for production iOS/Android builds
IRIS_REVENUECAT_API_KEY=YOUR_IRIS_REVENUECAT_PLATFORM_PUBLIC_API_KEY

# Firebase Project
FIREBASE_PROJECT_ID=stellium-relationship-prod

# Relationship App Backend Auth (Service Account)
# The service account key JSON file is at: secrets/relationship-app-backend-prod.json
# For backend deployment, set GOOGLE_APPLICATION_CREDENTIALS to point to this file,
# or use these individual env vars:
RELATIONSHIP_FIREBASE_SERVICE_ACCOUNT_EMAIL=relationship-app-backend@stellium-relationship-prod.iam.gserviceaccount.com
RELATIONSHIP_FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./secrets/relationship-app-backend-prod.json
RELATIONSHIP_FIREBASE_PROJECT_ID=stellium-relationship-prod

# Environment identifier
ENV=production
